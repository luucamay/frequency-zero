# Mistral AI API Key (required for text generation)
# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY="your_mistral_api_key"

# Mistral API key for client-side (if needed)
NEXT_PUBLIC_MISTRAL_API_KEY="your_mistral_api_key"

# ElevenLabs API Key (required for voice synthesis)
# Get your API key from https://elevenlabs.io/
ELEVENLABS_API_KEY="your_elevenlabs_api_key"

# ElevenLabs Voice ID (optional, defaults to "Adam" voice)
# Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID="pNInz6obpgDQGcFmaJgB"

# APP_URL: The URL where this applet is hosted
APP_URL="http://localhost:3000"
